---
import '../styles/global.css';
import { t, clientDicts, DEFAULT_LOCALE } from '../i18n';

const site = 'https://pluralty.com';
const canonical = new URL(Astro.url.pathname, site).href;
const title = t('meta.title');
const description = t('meta.desc');
const i18nData = JSON.stringify(clientDicts());

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Pluralty',
  url: site,
  description,
  areaServed: 'Latin America',
  knowsAbout: ['Cloud optimization', 'FinOps', 'DevOps', 'SRE', 'AWS', 'Azure', 'Google Cloud'],
  founder: {
    '@type': 'Person',
    name: 'Ariel Molina',
    jobTitle: 'Solutions Architect',
    sameAs: [
      'https://www.linkedin.com/in/arieldevops/',
      'https://x.com/ariel_devops',
      'https://www.youtube.com/@arieldevops',
      'https://www.instagram.com/arieldevops',
      'https://www.tiktok.com/@arieldevops',
      'https://builder.aws.com/community/@arieldevops',
    ],
  },
};
---

<!doctype html>
<html lang={DEFAULT_LOCALE} data-lang={DEFAULT_LOCALE}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0e0a14" />
    <title set:html={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/webp" href="/favicon.webp" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <link rel="alternate" hreflang="en" href={`${site}/?lang=en`} />
    <link rel="alternate" hreflang="es" href={`${site}/?lang=es`} />
    <link rel="alternate" hreflang="x-default" href={`${site}/`} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Pluralty" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${site}/og-image.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${site}/og-image.png`} />

    <!-- Pre-paint locale detection: URL ?lang > saved choice > browser language. -->
    <script is:inline>
      (function () {
        try {
          var p = new URLSearchParams(location.search).get('lang');
          var saved = null;
          try {
            saved = localStorage.getItem('pl-lang');
          } catch (e) {}
          var nav = (navigator.language || 'en').toLowerCase();
          var locale = p || saved || (nav.indexOf('es') === 0 ? 'es' : 'en');
          if (locale !== 'es' && locale !== 'en') locale = 'en';
          document.documentElement.setAttribute('lang', locale);
          document.documentElement.setAttribute('data-lang', locale);
        } catch (e) {}
      })();
    </script>

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/json" id="i18n-data" set:html={i18nData} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />

    <script>
      import '../scripts/i18n-client.ts';
      import '../scripts/reveal.ts';
    </script>

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--brand);
        color: #fff;
        padding: 10px 16px;
        border-radius: 0 0 var(--r-input) 0;
        z-index: 100;
      }
      .skip-link:focus {
        left: 0;
      }
    </style>
  </body>
</html>
