---
import Base from './Base.astro';
import logo from '../assets/isologotipo-blanco.webp';
import LangToggle from '../components/LangToggle.astro';
import Tr from '../components/Tr.astro';
import '../styles/case.css';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<Base title={title} description={description}>
  <header class="case-nav" id="site-nav">
    <div class="case-nav-inner">
      <a href="/" class="brand" aria-label="Pluralty homepage">
        <img src={logo.src} alt="Pluralty" width="140" height="32" />
      </a>
      <div class="case-nav-actions">
        <a href="/#cases" class="back-link">
          <Tr k="cases.back" />
        </a>
        <LangToggle />
      </div>
    </div>
  </header>

  <main id="main" class="case-main case">
    <slot />
  </main>

  <footer class="case-footer">
    <div class="case-footer-inner">
      <a href="/" class="footer-brand">
        <img src={logo.src} alt="Pluralty" width="120" height="28" />
      </a>
      <span class="footer-copy">© 2026 Pluralty</span>
    </div>
  </footer>
</Base>

<style>
  .case-nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    height: 68px;
    display: flex;
    align-items: center;
    background: rgba(14, 10, 20, 0.85);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--line);
  }
  .case-nav-inner {
    width: min(100% - 2 * var(--sp-5), var(--content));
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-5);
  }
  .brand img {
    height: 30px;
    width: auto;
  }
  .case-nav-actions {
    display: flex;
    align-items: center;
    gap: var(--sp-5);
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    color: var(--muted);
    font-size: var(--step-0);
    transition: color 0.2s;
  }
  .back-link:hover {
    color: var(--brand-glow);
  }
  .case-main {
    padding-top: 68px;
  }
  .case-footer {
    border-top: 1px solid var(--line);
    background: var(--ink-2);
    padding-block: var(--sp-6);
  }
  .case-footer-inner {
    width: min(100% - 2 * var(--sp-5), var(--content));
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
  }
  .footer-brand img {
    height: 26px;
    width: auto;
    opacity: 0.7;
  }
  .footer-copy {
    font-size: var(--step--1);
    color: var(--muted);
    font-family: var(--font-mono);
  }
</style>
