---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Problem from '../components/Problem.astro';
import Services from '../components/Services.astro';
import Assessment from '../components/Assessment.astro';
import CaseStudies from '../components/CaseStudies.astro';
import Partnerships from '../components/Partnerships.astro';
import CloudProviders from '../components/CloudProviders.astro';
import Founder from '../components/Founder.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<Base>
  <Nav />
  <main id="main">
    <Hero />
    <TrustStrip />
    <Problem />
    <Services />
    <Assessment />
    <CaseStudies />
    <Partnerships />
    <CloudProviders />
