---
import CaseLayout from '../../layouts/CaseLayout.astro';
import { t } from '../../i18n';
import CaseHero from '../../components/case/CaseHero.astro';
import CaseSection from '../../components/case/CaseSection.astro';
import CaseNumberedList from '../../components/case/CaseNumberedList.astro';
import CaseFigure from '../../components/case/CaseFigure.astro';
import CaseStack from '../../components/case/CaseStack.astro';
import CaseResults from '../../components/case/CaseResults.astro';
import CaseNextPrev from '../../components/case/CaseNextPrev.astro';
import CaseCta from '../../components/case/CaseCta.astro';
import Tr from '../../components/Tr.astro';

const stack = [
  { label: 'Amazon WorkSpaces', desc: 'Managed cloud desktops (AUTO_STOP)' },
  { label: 'AWS Directory Service', desc: 'Domain identity & centralized auth' },
  { label: 'AWS Backup', desc: 'Daily snapshots · 365-day retention' },
  { label: 'CloudWatch', desc: 'Monitoring & alerting' },
  { label: 'AWS Systems Manager', desc: 'Remote management & patching' },
  { label: 'AWS Budgets', desc: 'Cost threshold alerts' },
];

const facts = [
  { labelKey: 'case.facts.client', valueKey: 'case.pgsa.facts.client' },
  { labelKey: 'case.facts.industry', valueKey: 'case.pgsa.facts.industry' },
  { labelKey: 'case.facts.services', valueKey: 'case.pgsa.facts.services' },
  { labelKey: 'case.facts.platforms', valueKey: 'case.pgsa.facts.platforms' },
];

const metrics = [
  { vKey: 'case.pgsa.r1.v', lKey: 'case.pgsa.r1.l' },
  { vKey: 'case.pgsa.r2.v', lKey: 'case.pgsa.r2.l' },
  { vKey: 'case.pgsa.r3.v', lKey: 'case.pgsa.r3.l' },
  { vKey: 'case.pgsa.r4.v', lKey: 'case.pgsa.r4.l' },
];
---

<CaseLayout
  title={t('case.pgsa.meta.title')}
  description={t('case.pgsa.meta.desc')}
>
  <CaseHero
    initial="P"
    name="PGSA"
    tagKey="case.pgsa.tag"
    taglineKey="case.pgsa.tagline"
    badgeKey="case.pgsa.badge"
    facts={facts}
  />

  <CaseSection eyebrowKey="case.pgsa.challenge.label" titleKey="case.pgsa.challenge.title" id="challenge">
    <p><Tr k="case.pgsa.challenge.p1" /></p>
    <p><Tr k="case.pgsa.challenge.p2" /></p>
  </CaseSection>

  <CaseNumberedList
    eyebrowKey="case.pgsa.solution.label"
    titleKey="case.pgsa.solution.title"
    id="solution"
    alt
    items={[
      'case.pgsa.solution.p1',
      'case.pgsa.solution.p2',
      'case.pgsa.solution.p3',
    ]}
  />

  <CaseFigure captionKey="case.pgsa.arch.caption">
    <div class="arch-row">
      <div class="arch-box aws-box">
        <span class="arch-label">AWS Account — Single Region</span>
        <div class="arch-identity">
          <div class="identity-card">
            <span class="identity-name">AWS Directory Service</span>
            <div class="arch-services">
              <span class="svc">Domain Auth</span>
              <span class="svc">Centralized policies</span>
              <span class="svc">Domain-joined desktops</span>
            </div>
          </div>
        </div>
        <div class="arch-grid">
          <div class="arch-tile">
            <span class="tile-name">Amazon WorkSpaces</span>
            <div class="arch-services">
              <span class="svc">16 desktops</span>
              <span class="svc">Windows 10/11</span>
              <span class="svc">Custom corporate image</span>
              <span class="svc">AUTO_STOP billing</span>
            </div>
          </div>
          <div class="arch-tile">
            <span class="tile-name">AWS Backup</span>
            <div class="arch-services">
              <span class="svc">Daily snapshots</span>
              <span class="svc">365-day retention</span>
            </div>
          </div>
          <div class="arch-tile">
            <span class="tile-name">Ops & Visibility</span>
            <div class="arch-services">
              <span class="svc">CloudWatch</span>
              <span class="svc">Systems Manager</span>
              <span class="svc">AWS Budgets</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </CaseFigure>

  <CaseStack items={stack} titleKey="case.pgsa.stack.title" />

  <CaseResults
    eyebrowKey="case.pgsa.results.label"
    titleKey="case.pgsa.results.title"
    items={metrics}
  />

  <CaseNextPrev current="pgsa" />

  <CaseCta
    labelKey="case.pgsa.cta.label"
    titleKey="case.pgsa.cta.title"
    subKey="case.pgsa.cta.sub"
    btnKey="case.pgsa.cta.btn"
  />
</CaseLayout>
