---
import CaseLayout from '../../layouts/CaseLayout.astro';
import Tr from '../../components/Tr.astro';
import { t } from '../../i18n';

const stack = [
  { label: 'Amazon WorkSpaces', desc: 'Managed cloud desktops (AUTO_STOP)' },
  { label: 'AWS Directory Service', desc: 'Domain identity & centralized auth' },
  { label: 'AWS Backup', desc: 'Daily snapshots · 365-day retention' },
  { label: 'CloudWatch', desc: 'Monitoring & alerting' },
  { label: 'AWS Systems Manager', desc: 'Remote management & patching' },
  { label: 'AWS Budgets', desc: 'Cost threshold alerts' },
];
---

<CaseLayout
  title={t('case.pgsa.meta.title')}
  description={t('case.pgsa.meta.desc')}
>

  <!-- ─── Hero ──────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="wrap hero-inner">
      <div class="hero-copy" data-reveal>
        <div class="hero-meta">
          <span class="hero-logo">P</span>
          <span class="hero-tag"><Tr k="case.pgsa.tag" /></span>
        </div>
        <h1>PGSA</h1>
        <p class="hero-tagline"><Tr k="case.pgsa.tagline" /></p>
        <span class="hero-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          No public website · Privacy protected
        </span>
      </div>
      <div class="hero-art" aria-hidden="true" data-reveal>
        <div class="big-logo">P</div>
        <div class="glow-ring"></div>
      </div>
    </div>
  </section>

  <!-- ─── Metrics strip ─────────────────────────────────────────── -->
  <div class="metrics-band">
    <div class="wrap metrics-inner">
      <div class="metric" data-reveal>
        <span class="mv"><Tr k="case.pgsa.r1.v" /></span>
        <span class="ml"><Tr k="case.pgsa.r1.l" /></span>
      </div>
      <div class="metric" data-reveal>
        <span class="mv"><Tr k="case.pgsa.r2.v" /></span>
        <span class="ml"><Tr k="case.pgsa.r2.l" /></span>
      </div>
      <div class="metric" data-reveal>
        <span class="mv"><Tr k="case.pgsa.r3.v" /></span>
        <span class="ml"><Tr k="case.pgsa.r3.l" /></span>
      </div>
      <div class="metric" data-reveal>
        <span class="mv"><Tr k="case.pgsa.r4.v" /></span>
        <span class="ml"><Tr k="case.pgsa.r4.l" /></span>
      </div>
    </div>
  </div>

  <!-- ─── Challenge ─────────────────────────────────────────────── -->
  <section class="section" id="challenge">
    <div class="wrap two-col">
      <div class="col-label" data-reveal>
        <span class="eyebrow"><Tr k="case.pgsa.challenge.label" /></span>
      </div>
      <div class="col-content" data-reveal>
        <h2><Tr k="case.pgsa.challenge.title" /></h2>
        <p><Tr k="case.pgsa.challenge.p1" /></p>
        <p><Tr k="case.pgsa.challenge.p2" /></p>
      </div>
    </div>
  </section>

  <!-- ─── Solution ──────────────────────────────────────────────── -->
  <section class="section alt" id="solution">
    <div class="wrap two-col">
      <div class="col-label" data-reveal>
        <span class="eyebrow"><Tr k="case.pgsa.solution.label" /></span>
      </div>
      <div class="col-content" data-reveal>
        <h2><Tr k="case.pgsa.solution.title" /></h2>
        <div class="solution-step">
          <span class="step-num">01</span>
          <p><Tr k="case.pgsa.solution.p1" /></p>
        </div>
        <div class="solution-step">
          <span class="step-num">02</span>
          <p><Tr k="case.pgsa.solution.p2" /></p>
        </div>
        <div class="solution-step">
          <span class="step-num">03</span>
          <p><Tr k="case.pgsa.solution.p3" /></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Architecture diagram ─────────────────────────────────── -->
  <section class="section arch-section">
    <div class="wrap">
      <div class="arch-card" data-reveal>
        <div class="arch-row">
          <div class="arch-box aws-box">
            <span class="arch-label">AWS Account — Single Region</span>
            <div class="arch-identity">
              <div class="identity-card">
                <span class="identity-name">AWS Directory Service</span>
                <div class="arch-services">
                  <span class="svc">Domain Auth</span>
                  <span class="svc">Centralized policies</span>
                  <span class="svc">Domain-joined desktops</span>
                </div>
              </div>
            </div>
            <div class="arch-grid">
              <div class="arch-tile">
                <span class="tile-name">Amazon WorkSpaces</span>
                <div class="arch-services">
                  <span class="svc">16 desktops</span>
                  <span class="svc">Windows 10/11</span>
                  <span class="svc">Custom corporate image</span>
                  <span class="svc">AUTO_STOP billing</span>
                </div>
              </div>
              <div class="arch-tile">
                <span class="tile-name">AWS Backup</span>
                <div class="arch-services">
                  <span class="svc">Daily snapshots</span>
                  <span class="svc">365-day retention</span>
                </div>
              </div>
              <div class="arch-tile">
                <span class="tile-name">Ops & Visibility</span>
                <div class="arch-services">
                  <span class="svc">CloudWatch</span>
                  <span class="svc">Systems Manager</span>
                  <span class="svc">AWS Budgets</span>
                </div>
              </div>
            </div>
          </div>
        </div>
        <p class="arch-caption"><Tr k="case.pgsa.arch.caption" /></p>
      </div>
    </div>
  </section>

  <!-- ─── Stack ─────────────────────────────────────────────────── -->
  <section class="section" id="stack">
    <div class="wrap">
      <header class="stack-head" data-reveal>
        <span class="eyebrow"><Tr k="case.stack.eyebrow" /></span>
        <h2><Tr k="case.pgsa.stack.title" /></h2>
      </header>
      <ul class="stack-grid">
        {stack.map((s, i) => (
          <li class="stack-card" data-reveal style={`--reveal-delay:${i * 0.05}s`}>
            <span class="stack-name">{s.label}</span>
            <span class="stack-desc">{s.desc}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ─── Results ───────────────────────────────────────────────── -->
  <section class="section alt" id="results">
    <div class="wrap">
      <header class="results-head" data-reveal>
        <span class="eyebrow"><Tr k="case.pgsa.results.label" /></span>
        <h2><Tr k="case.pgsa.results.title" /></h2>
      </header>
      <div class="results-grid">
        <div class="result-card" data-reveal>
          <span class="rv"><Tr k="case.pgsa.r1.v" /></span>
          <span class="rl"><Tr k="case.pgsa.r1.l" /></span>
        </div>
        <div class="result-card" data-reveal>
          <span class="rv"><Tr k="case.pgsa.r2.v" /></span>
          <span class="rl"><Tr k="case.pgsa.r2.l" /></span>
        </div>
        <div class="result-card" data-reveal>
          <span class="rv"><Tr k="case.pgsa.r3.v" /></span>
          <span class="rl"><Tr k="case.pgsa.r3.l" /></span>
        </div>
        <div class="result-card" data-reveal>
          <span class="rv"><Tr k="case.pgsa.r4.v" /></span>
          <span class="rl"><Tr k="case.pgsa.r4.l" /></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CTA ───────────────────────────────────────────────────── -->
  <section class="cta-band">
    <div class="wrap cta-inner" data-reveal>
      <div class="cta-copy">
        <span class="eyebrow"><Tr k="case.pgsa.cta.label" /></span>
        <h2><Tr k="case.pgsa.cta.title" /></h2>
        <p><Tr k="case.pgsa.cta.sub" /></p>
      </div>
      <a class="btn btn-primary cta-btn" href="/#contact">
        <Tr k="case.pgsa.cta.btn" />
      </a>
    </div>
  </section>

</CaseLayout>

<style>
  .wrap {
    width: min(100% - 2 * var(--sp-5), var(--content));
    margin-inline: auto;
  }
  .hero {
    background: var(--ink);
    padding-block: clamp(80px, 16vh, 140px) clamp(60px, 10vh, 100px);
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at 80% 40%, rgba(123,47,181,0.22) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--sp-8);
    align-items: center;
  }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    margin-bottom: var(--sp-5);
  }
  .hero-logo {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(123,47,181,0.22);
    border: 1px solid rgba(123,47,181,0.4);
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    color: #9d5fd6;
    flex-shrink: 0;
  }
  .hero-tag {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--brand-glow);
    letter-spacing: 0.06em;
  }
  .hero-copy h1 {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--paper);
  }
  .hero-tagline {
    margin-top: var(--sp-5);
    font-size: var(--step-1);
    color: var(--muted);
    max-width: 48ch;
    line-height: 1.6;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: var(--sp-5);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--muted);
    border: 1px solid var(--line);
    padding: 6px 14px;
    border-radius: var(--r-pill);
  }
  .hero-art {
    position: relative;
    width: 200px;
    height: 200px;
    flex-shrink: 0;
  }
  .big-logo {
    width: 100%;
    height: 100%;
    border-radius: 36px;
    background: rgba(123,47,181,0.18);
    border: 1px solid rgba(123,47,181,0.35);
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 96px;
    color: #7b2fb5;
    position: relative;
    z-index: 1;
  }
  .glow-ring {
    position: absolute;
    inset: -24px;
    border-radius: 52px;
    border: 1px solid rgba(123,47,181,0.15);
    pointer-events: none;
  }
  .metrics-band {
    border-block: 1px solid var(--line);
    background: var(--ink-2);
  }
  .metrics-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }
  .metric {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    padding: var(--sp-7) var(--sp-6);
    border-right: 1px solid var(--line);
  }
  .metric:last-child { border-right: 0; }
  .mv {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--step-3);
    color: var(--brand-glow);
    letter-spacing: -0.02em;
  }
  .ml {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .section {
    padding-block: var(--section-y);
    background: var(--ink);
  }
  .section.alt { background: var(--ink-2); }
  .two-col {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--sp-8);
    align-items: start;
  }
  .col-label { padding-top: 6px; }
  .col-content h2 {
    font-size: var(--step-3);
    margin-bottom: var(--sp-6);
  }
  .col-content p {
    color: var(--muted);
    line-height: 1.75;
    max-width: 68ch;
    margin-bottom: var(--sp-5);
  }
  .col-content p:last-child { margin-bottom: 0; }
  .solution-step {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: var(--sp-4);
    margin-bottom: var(--sp-6);
    align-items: start;
  }
  .solution-step:last-child { margin-bottom: 0; }
  .step-num {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--brand-glow);
    padding-top: 4px;
    letter-spacing: 0.04em;
  }
  .solution-step p { margin-bottom: 0; }

  /* ── Architecture ── */
  .arch-section { border-block: 1px solid var(--line); }
  .arch-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-card);
    padding: var(--sp-7);
    overflow-x: auto;
  }
  .arch-row { min-width: 580px; }
  .aws-box {
    border: 1px dashed rgba(123,47,181,0.4);
    border-radius: 12px;
    padding: var(--sp-5);
  }
  .arch-label {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--brand-glow);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: var(--sp-4);
  }
  .arch-identity {
    margin-bottom: var(--sp-4);
  }
  .identity-card {
    background: rgba(123,47,181,0.08);
    border: 1px solid rgba(123,47,181,0.3);
    border-radius: 10px;
    padding: var(--sp-4) var(--sp-5);
    display: flex;
    align-items: center;
    gap: var(--sp-5);
    flex-wrap: wrap;
  }
  .identity-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step-0);
    color: var(--brand-glow);
    white-space: nowrap;
  }
  .arch-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-4);
  }
  .arch-tile {
    background: var(--ink);
    border: 1px solid var(--line-strong);
    border-radius: 10px;
    padding: var(--sp-4);
  }
  .tile-name {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step-0);
    color: var(--paper);
    margin-bottom: var(--sp-3);
  }
  .arch-services {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .svc {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 4px 8px;
    border: 1px solid var(--line-strong);
    border-radius: var(--r-pill);
    color: var(--paper);
    background: rgba(123,47,181,0.08);
  }
  .arch-caption {
    margin-top: var(--sp-5);
    font-size: var(--step--1);
    color: var(--muted);
    font-style: italic;
    padding-top: var(--sp-4);
    border-top: 1px solid var(--line);
  }

  .stack-head { margin-bottom: var(--sp-7); }
  .stack-head h2 {
    font-size: var(--step-3);
    margin-top: var(--sp-3);
  }
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--sp-3);
  }
  .stack-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-card);
    padding: var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    transition: border-color 0.2s, transform var(--dur) var(--ease);
  }
  .stack-card:hover {
    border-color: var(--line-strong);
    transform: translateY(-2px);
  }
  .stack-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step-0);
    color: var(--paper);
  }
  .stack-desc {
    font-size: var(--step--1);
    color: var(--muted);
    font-family: var(--font-mono);
  }

  .results-head { margin-bottom: var(--sp-7); }
  .results-head h2 {
    font-size: var(--step-3);
    margin-top: var(--sp-3);
  }
  .results-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-4);
  }
  .result-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-card);
    padding: var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    transition: border-color 0.2s;
  }
  .result-card:hover { border-color: rgba(123,47,181,0.5); }
  .rv {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--step-4);
    color: var(--brand-glow);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .rl {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.4;
  }

  .cta-band {
    background: linear-gradient(135deg, #1a0a2e 0%, #2d0f5a 50%, #1a0a2e 100%);
    border-top: 1px solid rgba(123,47,181,0.3);
    border-bottom: 1px solid rgba(123,47,181,0.3);
    padding-block: var(--sp-9);
  }
  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-7);
    flex-wrap: wrap;
  }
  .cta-copy { max-width: 54ch; }
  .cta-copy h2 {
    font-size: var(--step-3);
    margin-top: var(--sp-3);
    margin-bottom: var(--sp-4);
  }
  .cta-copy p { color: var(--muted); line-height: 1.7; }
  .cta-btn {
    white-space: nowrap;
    flex-shrink: 0;
    padding: 14px 28px;
    font-size: var(--step-1);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--brand-glow);
    display: block;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    border-radius: var(--r-pill);
    transition: background 0.2s, transform 0.2s;
    text-decoration: none;
  }
  .btn-primary {
    background: var(--brand);
    color: var(--paper);
    padding: 12px 24px;
  }
  .btn-primary:hover {
    background: var(--brand-lift);
    transform: translateY(-2px);
  }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-art { display: none; }
    .metrics-inner { grid-template-columns: repeat(2, 1fr); }
    .metric { border-bottom: 1px solid var(--line); }
    .metric:nth-child(2n) { border-right: 0; }
    .metric:nth-last-child(-n+2) { border-bottom: 0; }
    .two-col { grid-template-columns: 1fr; gap: var(--sp-5); }
    .col-label { padding-top: 0; }
    .results-grid { grid-template-columns: repeat(2, 1fr); }
    .arch-grid { grid-template-columns: 1fr; }
    .cta-inner { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 540px) {
    .metrics-inner { grid-template-columns: repeat(2, 1fr); }
    .results-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
