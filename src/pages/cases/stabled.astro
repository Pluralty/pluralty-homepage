---
import CaseLayout from '../../layouts/CaseLayout.astro';
import { t } from '../../i18n';
import CaseHero from '../../components/case/CaseHero.astro';
import CaseSection from '../../components/case/CaseSection.astro';
import CaseNumberedList from '../../components/case/CaseNumberedList.astro';
import CaseFigure from '../../components/case/CaseFigure.astro';
import CaseStack from '../../components/case/CaseStack.astro';
import CaseResults from '../../components/case/CaseResults.astro';
import CasePullQuote from '../../components/case/CasePullQuote.astro';
import CaseNextPrev from '../../components/case/CaseNextPrev.astro';
import CaseCta from '../../components/case/CaseCta.astro';
import Tr from '../../components/Tr.astro';

const stack = [
  { label: 'AWS Organizations', desc: 'Multi-account isolation' },
  { label: 'ECS Fargate', desc: 'Serverless containers' },
  { label: 'Application Load Balancer', desc: 'Traffic distribution' },
  { label: 'Aurora PostgreSQL Serverless v2', desc: 'Auto-scaling managed database' },
  { label: 'ECR', desc: 'Container registry' },
  { label: 'GitHub Actions', desc: 'CI/CD pipeline' },
  { label: 'Terraform', desc: 'Infrastructure as code' },
  { label: 'VPC + Private subnets', desc: 'Network isolation' },
];

const facts = [
  { labelKey: 'case.facts.client', valueKey: 'case.stabled.facts.client' },
  { labelKey: 'case.facts.industry', valueKey: 'case.stabled.facts.industry' },
  { labelKey: 'case.facts.services', valueKey: 'case.stabled.facts.services' },
  { labelKey: 'case.facts.platforms', valueKey: 'case.stabled.facts.platforms' },
];

const metrics = [
  { vKey: 'case.stabled.r1.v', lKey: 'case.stabled.r1.l' },
  { vKey: 'case.stabled.r2.v', lKey: 'case.stabled.r2.l' },
  { vKey: 'case.stabled.r3.v', lKey: 'case.stabled.r3.l' },
  { vKey: 'case.stabled.r4.v', lKey: 'case.stabled.r4.l' },
];
---

<CaseLayout
  title={t('case.stabled.meta.title')}
  description={t('case.stabled.meta.desc')}
>
  <CaseHero
    initial="S"
    name="Stabled"
    tagKey="case.stabled.tag"
    taglineKey="case.stabled.tagline"
    url="https://stabled.co"
    urlLabel="stabled.co"
    facts={facts}
  />

  <CaseSection eyebrowKey="case.stabled.challenge.label" titleKey="case.stabled.challenge.title" id="challenge">
    <p><Tr k="case.stabled.challenge.p1" /></p>
    <p><Tr k="case.stabled.challenge.p2" /></p>
  </CaseSection>

  <CaseNumberedList
    eyebrowKey="case.stabled.solution.label"
    titleKey="case.stabled.solution.title"
    id="solution"
    alt
    items={[
      'case.stabled.solution.p1',
      'case.stabled.solution.p2',
      'case.stabled.solution.p3',
    ]}
  />

  <CaseFigure captionKey="case.stabled.arch.caption">
    <div class="arch-row">
      <div class="arch-box aws-org">
        <span class="arch-label">AWS Organizations</span>
        <div class="arch-accounts">
          <div class="arch-account prod">
            <span>Production</span>
            <div class="arch-services">
              <span class="svc">ALB</span>
              <span class="svc">ECS: landing</span>
              <span class="svc">ECS: app</span>
              <span class="svc">ECS: api</span>
              <span class="svc">Aurora Serverless v2</span>
              <span class="svc">ECR</span>
            </div>
          </div>
          <div class="arch-account staging">
            <span>Staging</span>
            <div class="arch-services">
              <span class="svc">ECS Fargate</span>
              <span class="svc">RDS</span>
            </div>
          </div>
          <div class="arch-account tooling">
            <span>Tooling</span>
            <div class="arch-services">
              <span class="svc">GitHub Actions</span>
              <span class="svc">ECR shared</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </CaseFigure>

  <CaseStack items={stack} />

  <CaseResults
    eyebrowKey="case.stabled.results.label"
    titleKey="case.stabled.results.title"
    items={metrics}
  />

  <CasePullQuote
    quoteKey="case.stabled.quote"
    nameKey="case.stabled.quote.name"
    roleKey="case.stabled.quote.role"
    initial="N"
  />

  <CaseNextPrev current="stabled" />

  <CaseCta
    labelKey="case.stabled.cta.label"
    titleKey="case.stabled.cta.title"
    subKey="case.stabled.cta.sub"
    btnKey="case.stabled.cta.btn"
  />
</CaseLayout>
