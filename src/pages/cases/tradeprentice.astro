---
import CaseLayout from '../../layouts/CaseLayout.astro';
import Tr from '../../components/Tr.astro';
import { t } from '../../i18n';

const stack = [
  { label: 'AWS Organizations', desc: 'Multi-account isolation' },
  { label: 'ECS Fargate', desc: 'Serverless containers' },
  { label: 'Application Load Balancer', desc: 'Traffic routing' },
  { label: 'RDS PostgreSQL Multi-AZ', desc: 'High-availability database' },
  { label: 'ElastiCache Redis', desc: 'Session & query cache' },
  { label: 'WebSockets', desc: 'Real-time trading signals' },
  { label: 'WAF', desc: 'Web application firewall' },
  { label: 'GitHub Actions + OIDC', desc: 'Keyless CI/CD' },
  { label: 'Terraform', desc: 'Infrastructure as code' },
  { label: 'Secrets Manager', desc: 'Auto-rotating credentials' },
  { label: 'IAM Identity Center', desc: 'SSO & access governance' },
  { label: 'CloudWatch', desc: 'Metrics & log aggregation' },
  { label: 'ACM', desc: 'TLS certificate management' },
];
---

<CaseLayout
  title={t('case.tradeprentice.meta.title')}
  description={t('case.tradeprentice.meta.desc')}
>

  <!-- ─── Hero ──────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="wrap hero-inner">
      <div class="hero-copy" data-reveal>
        <div class="hero-meta">
          <span class="hero-logo">T</span>
          <span class="hero-tag"><Tr k="case.tradeprentice.tag" /></span>
        </div>
        <h1>Tradeprentice</h1>
        <p class="hero-tagline"><Tr k="case.tradeprentice.tagline" /></p>
        <a class="hero-url" href="https://tradeprentice.io" target="_blank" rel="noopener">
          tradeprentice.io
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M14 5h5v5M19 5l-8 8M11 5H7a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4"/>
          </svg>
        </a>
        <p class="hero-partner">
          <span class="partner-label"><Tr k="case.tradeprentice.via" /></span>
          <a href="https://spinlab.tech" target="_blank" rel="noopener" class="partner-link">SpinLab</a>
        </p>
      </div>
      <div class="hero-art" aria-hidden="true" data-reveal>
        <div class="big-logo">T</div>
        <div class="glow-ring"></div>
      </div>
    </div>
  </section>

  <!-- ─── Metrics strip ─────────────────────────────────────────── -->
  <div class="metrics-band">
    <div class="wrap metrics-inner">
      <div class="metric" data-reveal>
        <span class="mv"><Tr k="case.tradeprentice.r1.v" /></span>
        <span class="ml"><Tr k="case.tradeprentice.r1.l" /></span>
      </div>
      <div class="metric" data-reveal>
        <span class="mv"><Tr k="case.tradeprentice.r2.v" /></span>
        <span class="ml"><Tr k="case.tradeprentice.r2.l" /></span>
      </div>
      <div class="metric" data-reveal>
        <span class="mv"><Tr k="case.tradeprentice.r3.v" /></span>
        <span class="ml"><Tr k="case.tradeprentice.r3.l" /></span>
      </div>
      <div class="metric" data-reveal>
        <span class="mv"><Tr k="case.tradeprentice.r4.v" /></span>
        <span class="ml"><Tr k="case.tradeprentice.r4.l" /></span>
      </div>
    </div>
  </div>

  <!-- ─── Challenge ─────────────────────────────────────────────── -->
  <section class="section" id="challenge">
    <div class="wrap two-col">
      <div class="col-label" data-reveal>
        <span class="eyebrow"><Tr k="case.tradeprentice.challenge.label" /></span>
      </div>
      <div class="col-content" data-reveal>
        <h2><Tr k="case.tradeprentice.challenge.title" /></h2>
        <p><Tr k="case.tradeprentice.challenge.p1" /></p>
        <p><Tr k="case.tradeprentice.challenge.p2" /></p>
      </div>
    </div>
  </section>

  <!-- ─── Solution ──────────────────────────────────────────────── -->
  <section class="section alt" id="solution">
    <div class="wrap two-col">
      <div class="col-label" data-reveal>
        <span class="eyebrow"><Tr k="case.tradeprentice.solution.label" /></span>
      </div>
      <div class="col-content" data-reveal>
        <h2><Tr k="case.tradeprentice.solution.title" /></h2>
        <div class="solution-step">
          <span class="step-num">01</span>
          <p><Tr k="case.tradeprentice.solution.p1" /></p>
        </div>
        <div class="solution-step">
          <span class="step-num">02</span>
          <p><Tr k="case.tradeprentice.solution.p2" /></p>
        </div>
        <div class="solution-step">
          <span class="step-num">03</span>
          <p><Tr k="case.tradeprentice.solution.p3" /></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Architecture diagram ─────────────────────────────────── -->
  <section class="section arch-section">
    <div class="wrap">
      <div class="arch-card" data-reveal>
        <div class="arch-row">
          <div class="arch-box aws-org">
            <span class="arch-label">AWS Organizations</span>
            <div class="arch-top-row">
              <div class="arch-sso">
                <span class="sso-label">IAM Identity Center</span>
                <span class="sso-sub">SSO · MFA · Access governance</span>
              </div>
            </div>
            <div class="arch-accounts">
              <div class="arch-account dev-acc">
                <span>DEV Account</span>
                <div class="arch-services">
                  <span class="svc">ALB</span>
                  <span class="svc">ECS Fargate</span>
                  <span class="svc">RDS PostgreSQL</span>
                  <span class="svc">ElastiCache Redis</span>
                </div>
                <div class="acc-note"><Tr k="case.tradeprentice.arch.dev.note" /></div>
              </div>
              <div class="arch-account prod-acc">
                <span>PRD Account</span>
                <div class="arch-services">
                  <span class="svc">ALB (public + internal)</span>
                  <span class="svc">ECS: frontend</span>
                  <span class="svc">ECS: backend API</span>
                  <span class="svc">ECS: WebSocket</span>
                  <span class="svc">ECS: backoffice</span>
                  <span class="svc">ECS: cronjob</span>
                  <span class="svc">RDS Multi-AZ</span>
                  <span class="svc">ElastiCache Redis</span>
                </div>
                <div class="acc-note acc-note-prod"><Tr k="case.tradeprentice.arch.prod.note" /></div>
              </div>
            </div>
            <div class="arch-cicd-row">
              <div class="arch-cicd">
                <span class="svc svc-ci">GitHub Actions + OIDC</span>
                <span class="cicd-arrow">→</span>
                <span class="svc svc-tf">Terraform (S3 + DynamoDB)</span>
              </div>
            </div>
          </div>
        </div>
        <p class="arch-caption"><Tr k="case.tradeprentice.arch.caption" /></p>
      </div>
    </div>
  </section>

  <!-- ─── Stack ─────────────────────────────────────────────────── -->
  <section class="section" id="stack">
    <div class="wrap">
      <header class="stack-head" data-reveal>
        <span class="eyebrow"><Tr k="case.stack.eyebrow" /></span>
        <h2><Tr k="case.stack.title" /></h2>
      </header>
      <ul class="stack-grid">
        {stack.map((s, i) => (
          <li class="stack-card" data-reveal style={`--reveal-delay:${i * 0.05}s`}>
            <span class="stack-name">{s.label}</span>
            <span class="stack-desc">{s.desc}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ─── Testimonial ────────────────────────────────────────────── -->
  <section class="section alt quote-section">
    <div class="wrap">
      <blockquote class="quote-card" data-reveal>
        <p class="qt"><Tr k="case.tradeprentice.quote" /></p>
        <footer class="qf">
          <div class="qa">F</div>
          <div class="qm">
            <span class="qn"><Tr k="case.tradeprentice.quote.name" /></span>
            <span class="qr"><Tr k="case.tradeprentice.quote.role" /></span>
          </div>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- ─── Results ───────────────────────────────────────────────── -->
  <section class="section" id="results">
    <div class="wrap">
      <header class="results-head" data-reveal>
        <span class="eyebrow"><Tr k="case.tradeprentice.results.label" /></span>
        <h2><Tr k="case.tradeprentice.results.title" /></h2>
      </header>
      <div class="results-grid">
        <div class="result-card" data-reveal>
          <span class="rv"><Tr k="case.tradeprentice.r1.v" /></span>
          <span class="rl"><Tr k="case.tradeprentice.r1.l" /></span>
        </div>
        <div class="result-card" data-reveal>
          <span class="rv"><Tr k="case.tradeprentice.r2.v" /></span>
          <span class="rl"><Tr k="case.tradeprentice.r2.l" /></span>
        </div>
        <div class="result-card" data-reveal>
          <span class="rv"><Tr k="case.tradeprentice.r3.v" /></span>
          <span class="rl"><Tr k="case.tradeprentice.r3.l" /></span>
        </div>
        <div class="result-card" data-reveal>
          <span class="rv"><Tr k="case.tradeprentice.r4.v" /></span>
          <span class="rl"><Tr k="case.tradeprentice.r4.l" /></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CTA ───────────────────────────────────────────────────── -->
  <section class="cta-band">
    <div class="wrap cta-inner" data-reveal>
      <div class="cta-copy">
        <span class="eyebrow"><Tr k="case.tradeprentice.cta.label" /></span>
        <h2><Tr k="case.tradeprentice.cta.title" /></h2>
        <p><Tr k="case.tradeprentice.cta.sub" /></p>
      </div>
      <a class="btn btn-primary cta-btn" href="/#contact">
        <Tr k="case.tradeprentice.cta.btn" />
      </a>
    </div>
  </section>

</CaseLayout>

<style>
  /* ── Wrap ── */
  .wrap {
    width: min(100% - 2 * var(--sp-5), var(--content));
    margin-inline: auto;
  }

  /* ── Hero ── */
  .hero {
    background: var(--ink);
    padding-block: clamp(80px, 16vh, 140px) clamp(60px, 10vh, 100px);
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at 80% 40%, rgba(123,47,181,0.22) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--sp-8);
    align-items: center;
  }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    margin-bottom: var(--sp-5);
  }
  .hero-logo {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(123,47,181,0.22);
    border: 1px solid rgba(123,47,181,0.4);
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    color: #9d5fd6;
    flex-shrink: 0;
  }
  .hero-tag {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--brand-glow);
    letter-spacing: 0.06em;
  }
  .hero-copy h1 {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--paper);
  }
  .hero-tagline {
    margin-top: var(--sp-5);
    font-size: var(--step-1);
    color: var(--muted);
    max-width: 48ch;
    line-height: 1.6;
  }
  .hero-url {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: var(--sp-5);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--brand-glow);
    border: 1px solid rgba(157,95,214,0.3);
    padding: 6px 14px;
    border-radius: var(--r-pill);
    transition: background 0.2s, border-color 0.2s;
  }
  .hero-url:hover {
    background: rgba(157,95,214,0.08);
    border-color: rgba(157,95,214,0.6);
  }
  .hero-partner {
    margin-top: var(--sp-3);
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--step--1);
  }
  .partner-label {
    color: var(--muted);
    font-family: var(--font-mono);
  }
  .partner-link {
    color: var(--brand-glow);
    font-family: var(--font-mono);
    transition: opacity 0.2s;
  }
  .partner-link:hover { opacity: 0.8; }
  .hero-art {
    position: relative;
    width: 200px;
    height: 200px;
    flex-shrink: 0;
  }
  .big-logo {
    width: 100%;
    height: 100%;
    border-radius: 36px;
    background: rgba(123,47,181,0.18);
    border: 1px solid rgba(123,47,181,0.35);
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 96px;
    color: #7b2fb5;
    position: relative;
    z-index: 1;
  }
  .glow-ring {
    position: absolute;
    inset: -24px;
    border-radius: 52px;
    border: 1px solid rgba(123,47,181,0.15);
    pointer-events: none;
  }

  /* ── Metrics band ── */
  .metrics-band {
    border-block: 1px solid var(--line);
    background: var(--ink-2);
  }
  .metrics-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }
  .metric {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    padding: var(--sp-7) var(--sp-6);
    border-right: 1px solid var(--line);
  }
  .metric:last-child { border-right: 0; }
  .mv {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--step-3);
    color: var(--brand-glow);
    letter-spacing: -0.02em;
  }
  .ml {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ── Section base ── */
  .section {
    padding-block: var(--section-y);
    background: var(--ink);
  }
  .section.alt { background: var(--ink-2); }

  /* ── Two-col text ── */
  .two-col {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--sp-8);
    align-items: start;
  }
  .col-label { padding-top: 6px; }
  .col-content h2 {
    font-size: var(--step-3);
    margin-bottom: var(--sp-6);
  }
  .col-content p {
    color: var(--muted);
    line-height: 1.75;
    max-width: 68ch;
    margin-bottom: var(--sp-5);
  }
  .col-content p:last-child { margin-bottom: 0; }

  /* ── Solution steps ── */
  .solution-step {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: var(--sp-4);
    margin-bottom: var(--sp-6);
    align-items: start;
  }
  .solution-step:last-child { margin-bottom: 0; }
  .step-num {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--brand-glow);
    padding-top: 4px;
    letter-spacing: 0.04em;
  }
  .solution-step p { margin-bottom: 0; }

  /* ── Architecture ── */
  .arch-section { border-block: 1px solid var(--line); }
  .arch-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-card);
    padding: var(--sp-7);
    overflow-x: auto;
  }
  .arch-row { min-width: 640px; }
  .aws-org {
    border: 1px dashed rgba(123,47,181,0.4);
    border-radius: 12px;
    padding: var(--sp-5);
  }
  .arch-label {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--brand-glow);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: var(--sp-4);
  }
  .arch-top-row {
    margin-bottom: var(--sp-4);
  }
  .arch-sso {
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
    background: rgba(123,47,181,0.08);
    border: 1px solid rgba(123,47,181,0.3);
    border-radius: 8px;
    padding: var(--sp-3) var(--sp-4);
  }
  .sso-label {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--brand-glow);
    font-weight: 600;
  }
  .sso-sub {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
  }
  .arch-accounts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-4);
  }
  .arch-account {
    border: 1px solid var(--line-strong);
    border-radius: 10px;
    padding: var(--sp-4);
    background: var(--ink);
  }
  .arch-account > span {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--muted);
    margin-bottom: var(--sp-3);
    letter-spacing: 0.04em;
  }
  .prod-acc {
    border-color: rgba(123,47,181,0.5);
    background: rgba(123,47,181,0.05);
  }
  .prod-acc > span { color: var(--brand-glow); }
  .arch-services {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-bottom: var(--sp-3);
  }
  .svc {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 4px 8px;
    border: 1px solid var(--line-strong);
    border-radius: var(--r-pill);
    color: var(--paper);
    background: rgba(123,47,181,0.08);
  }
  .acc-note {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    font-style: italic;
  }
  .acc-note-prod { color: var(--brand-glow); }
  .arch-cicd-row {
    margin-top: var(--sp-4);
    border-top: 1px solid var(--line);
    padding-top: var(--sp-4);
  }
  .arch-cicd {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }
  .svc-ci {
    background: rgba(0,180,100,0.08);
    border-color: rgba(0,180,100,0.3);
    color: #4ade80;
  }
  .svc-tf {
    background: rgba(97,68,219,0.12);
  }
  .cicd-arrow {
    color: var(--muted);
    font-family: var(--font-mono);
  }
  .arch-caption {
    margin-top: var(--sp-5);
    font-size: var(--step--1);
    color: var(--muted);
    font-style: italic;
    padding-top: var(--sp-4);
    border-top: 1px solid var(--line);
  }

  /* ── Stack grid ── */
  .stack-head { margin-bottom: var(--sp-7); }
  .stack-head h2 {
    font-size: var(--step-3);
    margin-top: var(--sp-3);
  }
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--sp-3);
  }
  .stack-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-card);
    padding: var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    transition: border-color 0.2s, transform var(--dur) var(--ease);
  }
  .stack-card:hover {
    border-color: var(--line-strong);
    transform: translateY(-2px);
  }
  .stack-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step-0);
    color: var(--paper);
  }
  .stack-desc {
    font-size: var(--step--1);
    color: var(--muted);
    font-family: var(--font-mono);
  }

  /* ── Testimonial quote ── */
  .quote-section { background: var(--ink-2); }
  .quote-card {
    max-width: 780px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-7);
    background: var(--surface);
    border: 1px solid var(--line);
    border-left: 4px solid var(--brand);
    border-radius: var(--r-card);
  }
  .qt {
    font-size: var(--step-1);
    color: var(--paper);
    line-height: 1.7;
    font-style: italic;
    margin-bottom: var(--sp-6);
  }
  .qf {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }
  .qa {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(123,47,181,0.22);
    border: 1px solid rgba(123,47,181,0.4);
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    color: var(--brand-glow);
    flex-shrink: 0;
  }
  .qm {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .qn {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step-0);
    color: var(--paper);
  }
  .qr {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--muted);
  }

  /* ── Results grid ── */
  .results-head { margin-bottom: var(--sp-7); }
  .results-head h2 {
    font-size: var(--step-3);
    margin-top: var(--sp-3);
  }
  .results-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-4);
  }
  .result-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-card);
    padding: var(--sp-6);
    display: flex;
