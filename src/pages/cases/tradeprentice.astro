---
import CaseLayout from '../../layouts/CaseLayout.astro';
import { t } from '../../i18n';
import CaseHero from '../../components/case/CaseHero.astro';
import CaseSection from '../../components/case/CaseSection.astro';
import CaseNumberedList from '../../components/case/CaseNumberedList.astro';
import CaseFigure from '../../components/case/CaseFigure.astro';
import CaseStack from '../../components/case/CaseStack.astro';
import CaseResults from '../../components/case/CaseResults.astro';
import CasePullQuote from '../../components/case/CasePullQuote.astro';
import CaseNextPrev from '../../components/case/CaseNextPrev.astro';
import CaseCta from '../../components/case/CaseCta.astro';
import Tr from '../../components/Tr.astro';

const stack = [
  { label: 'AWS Organizations', desc: 'Multi-account isolation' },
  { label: 'ECS Fargate', desc: 'Serverless containers' },
  { label: 'Application Load Balancer', desc: 'Traffic routing' },
  { label: 'RDS PostgreSQL Multi-AZ', desc: 'High-availability database' },
  { label: 'ElastiCache Redis', desc: 'Session & query cache' },
  { label: 'WebSockets', desc: 'Real-time trading signals' },
  { label: 'WAF', desc: 'Web application firewall' },
  { label: 'GitHub Actions + OIDC', desc: 'Keyless CI/CD' },
  { label: 'Terraform', desc: 'Infrastructure as code' },
  { label: 'Secrets Manager', desc: 'Auto-rotating credentials' },
  { label: 'IAM Identity Center', desc: 'SSO & access governance' },
  { label: 'CloudWatch', desc: 'Metrics & log aggregation' },
  { label: 'ACM', desc: 'TLS certificate management' },
];

const facts = [
  { labelKey: 'case.facts.client', valueKey: 'case.tradeprentice.facts.client' },
  { labelKey: 'case.facts.industry', valueKey: 'case.tradeprentice.facts.industry' },
  { labelKey: 'case.facts.services', valueKey: 'case.tradeprentice.facts.services' },
  { labelKey: 'case.facts.platforms', valueKey: 'case.tradeprentice.facts.platforms' },
];

const metrics = [
  { vKey: 'case.tradeprentice.r1.v', lKey: 'case.tradeprentice.r1.l' },
  { vKey: 'case.tradeprentice.r2.v', lKey: 'case.tradeprentice.r2.l' },
  { vKey: 'case.tradeprentice.r3.v', lKey: 'case.tradeprentice.r3.l' },
  { vKey: 'case.tradeprentice.r4.v', lKey: 'case.tradeprentice.r4.l' },
];
---

<CaseLayout
  title={t('case.tradeprentice.meta.title')}
  description={t('case.tradeprentice.meta.desc')}
>
  <CaseHero
    initial="T"
    name="Tradeprentice"
    tagKey="case.tradeprentice.tag"
    taglineKey="case.tradeprentice.tagline"
    url="https://tradeprentice.io"
    urlLabel="tradeprentice.io"
    viaKey="case.tradeprentice.via"
    viaName="SpinLab"
    viaUrl="https://spinlab.tech"
    facts={facts}
  />

  <CaseSection eyebrowKey="case.tradeprentice.challenge.label" titleKey="case.tradeprentice.challenge.title" id="challenge">
    <p><Tr k="case.tradeprentice.challenge.p1" /></p>
    <p><Tr k="case.tradeprentice.challenge.p2" /></p>
  </CaseSection>

  <CaseNumberedList
    eyebrowKey="case.tradeprentice.solution.label"
    titleKey="case.tradeprentice.solution.title"
    id="solution"
    alt
    items={[
      'case.tradeprentice.solution.p1',
      'case.tradeprentice.solution.p2',
      'case.tradeprentice.solution.p3',
    ]}
  />

  <CaseFigure captionKey="case.tradeprentice.arch.caption">
    <div class="arch-row">
      <div class="arch-box aws-org">
        <span class="arch-label">AWS Organizations</span>
        <div class="arch-top-row">
          <div class="arch-sso">
            <span class="sso-label">IAM Identity Center</span>
            <span class="sso-sub">SSO · MFA · Access governance</span>
          </div>
        </div>
        <div class="arch-accounts two">
          <div class="arch-account dev-acc">
            <span>DEV Account</span>
            <div class="arch-services">
              <span class="svc">ALB</span>
              <span class="svc">ECS Fargate</span>
              <span class="svc">RDS PostgreSQL</span>
              <span class="svc">ElastiCache Redis</span>
            </div>
            <div class="acc-note"><Tr k="case.tradeprentice.arch.dev.note" /></div>
          </div>
          <div class="arch-account prod-acc">
            <span>PRD Account</span>
            <div class="arch-services">
              <span class="svc">ALB (public + internal)</span>
              <span class="svc">ECS: frontend</span>
              <span class="svc">ECS: backend API</span>
              <span class="svc">ECS: WebSocket</span>
              <span class="svc">ECS: backoffice</span>
              <span class="svc">ECS: cronjob</span>
              <span class="svc">RDS Multi-AZ</span>
              <span class="svc">ElastiCache Redis</span>
            </div>
            <div class="acc-note acc-note-prod"><Tr k="case.tradeprentice.arch.prod.note" /></div>
          </div>
        </div>
        <div class="arch-cicd-row">
          <div class="arch-cicd">
            <span class="svc svc-ci">GitHub Actions + OIDC</span>
            <span class="cicd-arrow">→</span>
            <span class="svc svc-tf">Terraform (S3 + DynamoDB)</span>
          </div>
        </div>
      </div>
    </div>
  </CaseFigure>

  <CaseStack items={stack} />

  <CaseResults
    eyebrowKey="case.tradeprentice.results.label"
    titleKey="case.tradeprentice.results.title"
    items={metrics}
  />

  <CasePullQuote
    quoteKey="case.tradeprentice.quote"
    nameKey="case.tradeprentice.quote.name"
    roleKey="case.tradeprentice.quote.role"
    initial="F"
  />

  <CaseNextPrev current="tradeprentice" />

  <CaseCta
    labelKey="case.tradeprentice.cta.label"
    titleKey="case.tradeprentice.cta.title"
    subKey="case.tradeprentice.cta.sub"
    btnKey="case.tradeprentice.cta.btn"
  />
</CaseLayout>
