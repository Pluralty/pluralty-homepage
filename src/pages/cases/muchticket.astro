---
import CaseLayout from '../../layouts/CaseLayout.astro';
import { t } from '../../i18n';
import CaseHero from '../../components/case/CaseHero.astro';
import CaseSection from '../../components/case/CaseSection.astro';
import CaseNumberedList from '../../components/case/CaseNumberedList.astro';
import CaseFigure from '../../components/case/CaseFigure.astro';
import CaseStack from '../../components/case/CaseStack.astro';
import CaseResults from '../../components/case/CaseResults.astro';
import CasePullQuote from '../../components/case/CasePullQuote.astro';
import CaseNextPrev from '../../components/case/CaseNextPrev.astro';
import CaseCta from '../../components/case/CaseCta.astro';
import Tr from '../../components/Tr.astro';

const stack = [
  { label: 'Prometheus', desc: 'Time-series metrics engine' },
  { label: 'Grafana', desc: 'Real-time dashboards & alerts' },
  { label: 'BlackBox Exporter', desc: 'External HTTP endpoint probing' },
  { label: 'Telegram Bot', desc: 'Instant on-call alerting' },
  { label: 'Node Exporter', desc: 'Server-level OS metrics' },
  { label: 'Alertmanager', desc: 'Alert routing & deduplication' },
];

const facts = [
  { labelKey: 'case.facts.client', valueKey: 'case.muchticket.facts.client' },
  { labelKey: 'case.facts.industry', valueKey: 'case.muchticket.facts.industry' },
  { labelKey: 'case.facts.services', valueKey: 'case.muchticket.facts.services' },
  { labelKey: 'case.facts.platforms', valueKey: 'case.muchticket.facts.platforms' },
];

const metrics = [
  { vKey: 'case.muchticket.r1.v', lKey: 'case.muchticket.r1.l' },
  { vKey: 'case.muchticket.r2.v', lKey: 'case.muchticket.r2.l' },
  { vKey: 'case.muchticket.r3.v', lKey: 'case.muchticket.r3.l' },
  { vKey: 'case.muchticket.r4.v', lKey: 'case.muchticket.r4.l' },
];
---

<CaseLayout
  title={t('case.muchticket.meta.title')}
  description={t('case.muchticket.meta.desc')}
>
  <CaseHero
    initial="M"
    name="Muchticket"
    tagKey="case.muchticket.tag"
    taglineKey="case.muchticket.tagline"
    url="https://www.muchticket.com"
    urlLabel="muchticket.com"
    facts={facts}
  />

  <CaseSection eyebrowKey="case.muchticket.challenge.label" titleKey="case.muchticket.challenge.title" id="challenge">
    <p><Tr k="case.muchticket.challenge.p1" /></p>
    <p><Tr k="case.muchticket.challenge.p2" /></p>
  </CaseSection>

  <CaseNumberedList
    eyebrowKey="case.muchticket.solution.label"
    titleKey="case.muchticket.solution.title"
    id="solution"
    alt
    items={[
      'case.muchticket.solution.p1',
      'case.muchticket.solution.p2',
      'case.muchticket.solution.p3',
    ]}
  />

  <CaseFigure captionKey="case.muchticket.arch.caption">
    <div class="arch-row">
      <div class="arch-box infra-box">
        <span class="arch-label">On-Premise Infrastructure</span>
        <div class="arch-servers">
          <div class="arch-server"><span class="svc">Web Server</span></div>
          <div class="arch-server"><span class="svc">Queue Worker</span></div>
          <div class="arch-server"><span class="svc">DB Server</span></div>
          <div class="arch-server"><span class="svc">App Server N</span></div>
        </div>
        <div class="arch-arrow-row">
          <span class="arch-arrow-line"></span>
          <span class="arch-arrow-label">metrics scrape (pull)</span>
          <span class="arch-arrow-line"></span>
        </div>
        <div class="arch-obs-stack">
          <div class="arch-obs-center">
            <div class="obs-prom">
              <span class="obs-name">Prometheus</span>
              <span class="obs-desc">Time-series storage & alerting</span>
            </div>
          </div>
          <div class="arch-obs-outputs">
            <div class="obs-output">
              <span class="svc svc-grafana">Grafana</span>
              <span class="obs-sub">Dashboards & trends</span>
            </div>
            <div class="obs-output">
              <span class="svc svc-blackbox">BlackBox Exporter</span>
              <span class="obs-sub">HTTP endpoint probing</span>
            </div>
            <div class="obs-output">
              <span class="svc svc-telegram">Telegram Bot</span>
              <span class="obs-sub">On-call alerts in seconds</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </CaseFigure>

  <CaseStack items={stack} />

  <CaseResults
    eyebrowKey="case.muchticket.results.label"
    titleKey="case.muchticket.results.title"
    items={metrics}
  />

  <CasePullQuote
    quoteKey="case.muchticket.quote"
    nameKey="case.muchticket.quote.name"
    roleKey="case.muchticket.quote.role"
    initial="L"
  />

  <CaseNextPrev current="muchticket" />

  <CaseCta
    labelKey="case.muchticket.cta.label"
    titleKey="case.muchticket.cta.title"
    subKey="case.muchticket.cta.sub"
    btnKey="case.muchticket.cta.btn"
  />
</CaseLayout>
