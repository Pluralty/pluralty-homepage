---
import Base from '../layouts/Base.astro';
import isologo from '../assets/isologo-blanco.webp';
---

<Base>
  <main class="nf">
    <img src={isologo.src} alt="Pluralty" width="80" height="80" />
    <p class="code">404</p>
    <h1>Page not found</h1>
    <p class="sub">The page you are looking for moved or never existed.</p>
    <a class="btn btn-primary" href="/">Back home</a>
  </main>
</Base>

<style>
  .nf {
    min-height: 100svh;
    display: grid;
    place-content: center;
    justify-items: center;
    gap: var(--sp-3);
    text-align: center;
    padding: var(--sp-6);
  }
  .nf img {
    width: 72px;
    height: auto;
    margin-bottom: var(--sp-4);
    opacity: 0.9;
  }
  .code {
    font-family: var(--font-mono);
    color: var(--brand-glow);
    letter-spacing: 0.3em;
  }
  .nf h1 {
    font-size: var(--step-4);
  }
  .sub {
    color: var(--muted);
    margin-bottom: var(--sp-5);
  }
</style>
