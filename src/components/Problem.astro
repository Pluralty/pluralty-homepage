---
import Tr from './Tr.astro';
---

<section class="section" id="problem">
  <div class="wrap inner">
    <div class="copy" data-reveal>
      <span class="eyebrow"><Tr k="problem.eyebrow" /></span>
      <h2><Tr k="problem.title" as="span" /></h2>
      <p><Tr k="problem.p1" as="span" /></p>
      <p><Tr k="problem.p2" as="span" /></p>
    </div>
    <div class="result" data-reveal style="--reveal-delay:.1s">
      <span class="result-label"><Tr k="problem.result.label" /></span>
      <p><Tr k="problem.result.text" as="span" /></p>
    </div>
  </div>
</section>

<style>
  .section {
    background: var(--ink-2);
    border-block: 1px solid var(--line);
  }
  .inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: var(--sp-8);
    align-items: start;
    padding-block: var(--section-y);
  }
  .eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--brand-glow);
    margin-bottom: var(--sp-5);
  }
  .copy h2 {
    font-size: var(--step-3);
    line-height: 1.2;
    max-width: 22ch;
    margin-bottom: var(--sp-6);
  }
  .copy p {
    color: var(--muted);
    max-width: 56ch;
    line-height: 1.75;
    margin-bottom: var(--sp-4);
  }
  .copy p:last-child {
    margin-bottom: 0;
  }
  .result {
    background: var(--surface);
    border: 1px solid var(--line-strong);
    border-left: 4px solid var(--brand-lift);
    border-radius: 0 var(--r-card) var(--r-card) 0;
    padding: var(--sp-6) var(--sp-7);
    align-self: center;
  }
  .result-label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-glow);
    margin-bottom: var(--sp-4);
  }
  .result p {
    color: var(--paper);
    line-height: 1.7;
    font-size: var(--step-1);
  }

  @media (max-width: 820px) {
    .inner {
      grid-template-columns: 1fr;
      gap: var(--sp-6);
    }
    .copy h2 {
      max-width: none;
    }
  }
</style>
