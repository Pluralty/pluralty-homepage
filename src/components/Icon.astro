---
// Inline SVG icon set. Stroke icons inherit currentColor. One consistent
// 1.75 stroke weight across the UI; brand logos use their own fills.
interface Props {
  name: string;
  size?: number;
  class?: string;
}
const { name, size = 24, class: className } = Astro.props;

const stroke: Record<string, string> = {
  arrow:
    '<path d="M5 12h14M13 6l6 6-6 6"/>',
  check: '<path d="M20 6 9 17l-5-5"/>',
  external:
    '<path d="M14 5h5v5M19 5l-8 8M11 5H7a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4"/>',
  gauge:
    '<path d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/><path d="M12 14 8 9"/><path d="M3 18a9 9 0 1 1 18 0"/>',
  coins:
    '<circle cx="9" cy="9" r="6"/><path d="M16.5 6.5a6 6 0 1 1-5 10.9"/><path d="M9 6v6M7 8.5h2.5a1.5 1.5 0 0 1 0 3H7"/>',
  refresh:
    '<path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/><path d="M3 21v-5h5"/>',
  infinity:
    '<path d="M6 16c2.5 0 4-2 6-4s3.5-4 6-4a4 4 0 0 1 0 8c-2.5 0-4-2-6-4s-3.5-4-6-4a4 4 0 0 0 0 8Z"/>',
  shield:
    '<path d="M12 3 5 6v6c0 4.5 3 7.5 7 9 4-1.5 7-4.5 7-9V6l-7-3Z"/><path d="m9 12 2 2 4-4"/>',
  menu: '<path d="M4 7h16M4 12h16M4 17h16"/>',
  close: '<path d="M6 6l12 12M18 6 6 18"/>',
};

const brand: Record<string, string> = {
  // Social icons — explicit stroke/fill so they render regardless of SVG wrapper attrs
  youtube:
    '<rect x="2" y="5" width="20" height="14" rx="3" fill="none" stroke="currentColor" stroke-width="1.75"/><path d="m10 9 6 3-6 3Z" fill="currentColor" stroke="none"/>',
  x: '<path d="M4 4 20 20M20 4 4 20" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>',
  linkedin:
    '<rect x="3" y="3" width="18" height="18" rx="2" fill="none" stroke="currentColor" stroke-width="1.75"/><path d="M8 11v6M8 8h.01M12 17v-6M12 13a3 3 0 0 1 6 0v4" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>',
  instagram:
    '<rect x="3" y="3" width="18" height="18" rx="5" fill="none" stroke="currentColor" stroke-width="1.75"/><circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.75"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>',
  tiktok:
    '<path d="M15 4c.5 2.5 2 4 4.5 4.2v3C17.8 11 16.3 10.4 15 9.4V15a5.5 5.5 0 1 1-5.5-5.5c.3 0 .7 0 1 .1v3.1a2.5 2.5 0 1 0 1.5 2.3V4Z" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>',
  // Brand logos
  aws: '<path d="M7 14c2.5 1.5 7.5 1.5 10 0M5 10.5c0 1.4 1 2 2 2M8 8.5c-.6 0-1 .4-1 1.2M11 12.5V9c0-.8.6-1.2 1.2-.6M14 9v3.5M14 9c.4-.6 1.2-.6 1.5 0 .4-.6 1.2-.6 1.5 0v3.5" stroke="currentColor"/>',
  azure:
    '<path d="M11.5 3L2 20.5h5.5l3-6.5 4.5 8.5H21L14 9.5z" fill="currentColor" stroke="none"/>',
  gcp:
    '<path d="M17.5 10A5.5 5.5 0 0 0 7 11H6.5a4 4 0 1 0 0 8h11a3.5 3.5 0 0 0 0-7z" fill="currentColor" stroke="none"/>',
};

const isBrand = name in brand;
const body = brand[name] ?? stroke[name] ?? '';
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke={isBrand ? 'none' : 'currentColor'}
  stroke-width="1.75"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
  set:html={body}
/>
