---
import isologo from '../assets/isologo-blanco.webp';
import Tr from './Tr.astro';
import Icon from './Icon.astro';
---

<section class="hero" id="top">
  <div class="grain" aria-hidden="true"></div>
  <div class="wrap hero-grid">
    <div class="hero-copy">
      <span class="badge" data-reveal>
        <span class="dot" aria-hidden="true"></span>
        <Tr k="hero.badge" />
      </span>
      <h1 data-reveal style="--reveal-delay:.05s"><Tr k="hero.title" as="span" /></h1>
      <p class="lead" data-reveal style="--reveal-delay:.12s"><Tr k="hero.sub" as="span" /></p>
      <div class="cta-row" data-reveal style="--reveal-delay:.18s">
        <a class="btn btn-primary" href="#contact">
          <Tr k="hero.cta1" /><Icon name="arrow" size={18} />
        </a>
        <a class="btn btn-ghost" href="#cases"><Tr k="hero.cta2" /></a>
      </div>
    </div>

    <div class="hero-art" aria-hidden="true" data-reveal style="--reveal-delay:.1s">
      <svg class="circuit" viewBox="0 0 400 460" fill="none" preserveAspectRatio="xMidYMid meet">
        <defs>
          <radialGradient id="halo" cx="50%" cy="42%" r="55%">
            <stop offset="0%" stop-color="#7b2fb5" stop-opacity="0.55" />
            <stop offset="100%" stop-color="#7b2fb5" stop-opacity="0" />
          </radialGradient>
        </defs>
        <circle cx="200" cy="195" r="170" fill="url(#halo)" />
        <!-- circuit lines feeding the node -->
        <path class="trace" d="M20 70 H120 a16 16 0 0 1 16 16 V150" />
        <path class="trace" d="M380 110 H300 a16 16 0 0 0 -16 16 V180" />
        <path class="trace" d="M40 400 H150 a16 16 0 0 0 16 -16 V300" />
        <path class="trace" d="M360 410 H280 a16 16 0 0 1 -16 -16 V300" />
        <circle class="node" cx="20" cy="70" r="5" />
        <circle class="node" cx="380" cy="110" r="5" />
        <circle class="node" cx="40" cy="400" r="5" />
        <circle class="node" cx="360" cy="410" r="5" />
      </svg>
      <img class="mark" src={isologo.src} alt="" width="220" height="220" />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: 96px;
    padding-bottom: var(--sp-8);
    overflow: hidden;
  }
  .grain {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(60% 50% at 78% 30%, rgba(75, 0, 118, 0.4), transparent 70%),
      radial-gradient(50% 40% at 8% 80%, rgba(123, 47, 181, 0.16), transparent 70%);
    pointer-events: none;
  }
  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    align-items: center;
    gap: var(--sp-7);
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    color: var(--paper);
    padding: 7px 14px;
    border: 1px solid var(--line-strong);
    border-radius: var(--r-pill);
    background: rgba(123, 47, 181, 0.08);
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--brand-glow);
    box-shadow: 0 0 0 0 rgba(157, 95, 214, 0.6);
    animation: pulse 2.6s var(--ease) infinite;
  }
  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(157, 95, 214, 0.5);
    }
    70% {
      box-shadow: 0 0 0 10px rgba(157, 95, 214, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(157, 95, 214, 0);
    }
  }
  h1 {
    font-size: var(--step-5);
    margin-top: var(--sp-5);
    max-width: 14ch;
  }
  .hero-copy .lead {
    margin-top: var(--sp-4);
  }
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-top: var(--sp-6);
  }

  .hero-art {
    position: relative;
    display: grid;
    place-items: center;
    aspect-ratio: 1;
  }
  .circuit {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .mark {
    position: relative;
    width: min(48%, 220px);
    height: auto;
    filter: drop-shadow(0 14px 40px rgba(123, 47, 181, 0.45));
    animation: float 7s var(--ease) infinite;
  }
  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }
  .trace {
    stroke: var(--brand-lift);
    stroke-width: 2;
    stroke-linecap: round;
    fill: none;
    stroke-dasharray: 300;
    stroke-dashoffset: 300;
    animation: draw 2s var(--ease) forwards;
  }
  .trace:nth-of-type(3) {
    animation-delay: 0.25s;
  }
  .node {
    fill: var(--brand-glow);
    opacity: 0;
    animation: fadein 0.6s ease forwards 1.4s;
  }
  @keyframes draw {
    to {
      stroke-dashoffset: 0;
    }
  }
  @keyframes fadein {
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mark,
    .dot {
      animation: none;
    }
    .trace {
      stroke-dashoffset: 0;
      animation: none;
    }
    .node {
      opacity: 1;
      animation: none;
    }
  }

  @media (max-width: 860px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--sp-6);
    }
    .hero-art {
      order: -1;
      max-width: 340px;
      margin-inline: auto;
    }
    h1 {
      max-width: 18ch;
    }
  }
</style>
