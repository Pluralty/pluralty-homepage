---
import Tr from './Tr.astro';
import Icon from './Icon.astro';

interface Props {
  name: string;
  url: string;
  display: string;
  id: string;
  stack: string[];
  index: number;
}
const { name, url, display, id, stack, index } = Astro.props;
---

<article class="case" data-reveal style={`--reveal-delay:${index * 0.06}s`}>
  <div class="connector" aria-hidden="true"></div>
  <div class="body">
    <div class="meta">
      <span class="num">{String(index + 1).padStart(2, '0')}</span>
      <span class="tag"><Tr k={`cases.${id}.tag`} /></span>
    </div>
    <h3>{display}</h3>
    <p><Tr k={`cases.${id}.desc`} as="span" /></p>
    <a class="visit" href={url} target="_blank" rel="noopener">
      <Tr k="cases.visit" /> <span class="dom">{name}</span><Icon name="external" size={16} />
    </a>
  </div>
  <div class="stack">
    <span class="stack-label"><Tr k="cases.stack" /></span>
    <ul>
      {stack.map((s) => <li>{s}</li>)}
    </ul>
    <span class="soon"><Tr k="cases.soon" /></span>
  </div>
</article>

<style>
  .case {
    position: relative;
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--sp-6);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-card);
    padding: var(--sp-6) var(--sp-6) var(--sp-6) var(--sp-7);
    overflow: hidden;
    transition: border-color 0.3s, transform var(--dur) var(--ease);
  }
  .case:hover {
    border-color: var(--line-strong);
    transform: translateY(-3px);
  }
  /* the "plug" connector echoing the isologo port motif */
  .connector {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 5px;
    height: 60%;
    background: linear-gradient(var(--brand-lift), var(--brand));
    border-radius: 0 5px 5px 0;
  }
  .meta {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-3);
  }
  .num {
    font-family: var(--font-mono);
    color: var(--brand-glow);
    font-size: var(--step--1);
  }
  .tag {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--muted);
    letter-spacing: 0.04em;
  }
  .case h3 {
    font-size: var(--step-3);
  }
  .body p {
    margin-top: var(--sp-3);
    color: var(--muted);
    max-width: 52ch;
  }
  .visit {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: var(--sp-4);
    color: var(--paper);
    font-weight: 600;
    transition: color 0.2s;
  }
  .visit:hover {
    color: var(--brand-glow);
  }
  .visit .dom {
    color: var(--brand-glow);
  }
  .stack {
    border-left: 1px solid var(--line);
    padding-left: var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .stack-label {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
  }
  .stack ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .stack li {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    padding: 5px 10px;
    border: 1px solid var(--line-strong);
    border-radius: var(--r-pill);
    color: var(--paper);
    background: rgba(123, 47, 181, 0.08);
  }
  .soon {
    margin-top: auto;
    font-size: var(--step--1);
    color: var(--muted);
    font-style: italic;
  }

  @media (max-width: 800px) {
    .case {
      grid-template-columns: 1fr;
      gap: var(--sp-5);
    }
    .stack {
      border-left: 0;
      border-top: 1px solid var(--line);
      padding-left: 0;
      padding-top: var(--sp-5);
    }
  }
</style>
