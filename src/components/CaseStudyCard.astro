---
import Tr from './Tr.astro';
import Icon from './Icon.astro';

interface Props {
  detailUrl?: string;
  display: string;
  id: string;
  stack: string[];
  index: number;
  logoImg?: { src: string };
  logoBg?: string;
  logoText?: string;
}
const {
  detailUrl,
  display,
  id,
  stack,
  logoImg,
  logoBg = 'rgba(123,47,181,0.15)',
  logoText,
} = Astro.props;

const topStack = stack.slice(0, 3);
const Tag = detailUrl ? 'a' : 'div';
---

<Tag class="case" href={detailUrl} style={`--lb:${logoBg}`}>
  <!-- Logo banner: client logo centered on its brand color, air on the sides -->
  <div class="banner">
    {logoImg
      ? <img src={logoImg.src} alt={display} class="logo-img" loading="lazy" decoding="async" />
      : <span class="banner-text">{logoText}</span>
    }
  </div>

  <!-- Body: tag (1 line) · name · description (2 lines) · stack · CTA -->
  <div class="body">
    <Tr k={`cases.${id}.tag`} as="span" class="tag" />
    <h3>{display}</h3>
    <Tr k={`cases.${id}.desc`} as="p" class="desc" />
    <ul class="stack-tags">
      {topStack.map((s: string) => <li>{s}</li>)}
    </ul>
    {detailUrl && (
      <span class="cta">
        <Tr k="cases.read" /><Icon name="arrow" size={15} />
      </span>
    )}
  </div>
</Tag>

<style>
  .case {
    display: flex;
    flex-direction: column;
    border-radius: var(--r-card);
    border: 1px solid var(--line);
    background: var(--surface);
    overflow: hidden;
    transition: border-color 0.25s var(--ease), transform 0.25s var(--ease),
      box-shadow 0.25s var(--ease);
  }

  /* Logo banner */
  .banner {
    height: 150px;
    display: grid;
    place-items: center;
    padding: var(--sp-5) var(--sp-7);
    background: var(--lb);
  }
  .logo-img {
    max-width: 62%;
    max-height: 64px;
    object-fit: contain;
  }
  .banner-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--step-3);
    color: #fff;
    letter-spacing: 0.04em;
  }

  /* Body */
  .body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-5);
    flex: 1;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--brand-glow);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    /* always one line */
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .body h3 {
    font-size: var(--step-2);
    color: var(--paper);
  }
  .desc {
    color: var(--muted);
    font-size: var(--step--1);
    line-height: 1.55;
    /* always exactly two lines: reserve the height, clamp the overflow */
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    overflow: hidden;
    min-height: calc(2 * 1.55em);
  }
  .stack-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .stack-tags li {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    padding: 3px 8px;
    border: 1px solid var(--line-strong);
    border-radius: var(--r-pill);
    color: var(--muted);
    background: rgba(123, 47, 181, 0.10);
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--brand-glow);
    font-weight: 600;
    font-size: var(--step--1);
    margin-top: auto;
  }
  .cta :global(svg) {
    transition: transform 0.25s var(--ease);
  }

  /* Calm hover: lift + accent, never covers the logo */
  .case[href]:hover {
    border-color: var(--line-strong);
    transform: translateY(-4px);
    box-shadow: var(--shadow-violet);
  }
  .case[href]:hover .cta :global(svg) {
    transform: translateX(4px);
  }
</style>
