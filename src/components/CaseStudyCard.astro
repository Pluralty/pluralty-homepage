---
import Tr from './Tr.astro';
import Icon from './Icon.astro';
import { t } from '../i18n';

interface Props {
  name?: string;
  url?: string;
  detailUrl?: string;
  display: string;
  id: string;
  stack: string[];
  index: number;
  logoImg?: { src: string };
  logoColor?: string;
  logoBg?: string;
  logoText?: string;
}
const {
  name,
  url,
  detailUrl,
  display,
  id,
  stack,
  index,
  logoImg,
  logoColor = 'var(--brand-glow)',
  logoBg = 'rgba(123,47,181,0.15)',
  logoText,
} = Astro.props;

const fullDesc = t(`cases.${id}.desc`);
const shortDesc = fullDesc.split('.')[0] + '.';
const topStack = stack.slice(0, 3);
---

<article
  class="case"
  data-reveal
  style={`--reveal-delay:${index * 0.06}s;--lc:${logoColor};--lb:${logoBg}`}
>
  <!-- FRONT: logo fills the card -->
  <div class="front">
    {logoImg
      ? <img src={logoImg.src} alt={display} class="logo-img" loading="lazy" decoding="async" />
      : <span class="mono">{logoText}</span>
    }
  </div>

  <!-- BACK: slides up on hover -->
  <div class="back">
    <div class="back-top">
      <span class="tag"><Tr k={`cases.${id}.tag`} /></span>
      <h3>{display}</h3>
      <p class="desc">{shortDesc}</p>
    </div>
    <div class="back-bottom">
      <ul class="stack-tags">
        {topStack.map((s: string) => <li>{s}</li>)}
      </ul>
      <div class="actions">
        {detailUrl && (
          <a class="read-more" href={detailUrl}>
            <Tr k="cases.read" /><Icon name="arrow" size={15} />
          </a>
        )}
        {url && (
          <a class="visit" href={url} target="_blank" rel="noopener">
            <span class="dom">{name}</span><Icon name="external" size={14} />
          </a>
        )}
        {!url && !detailUrl && (
          <span class="no-url"><Tr k="cases.soon" /></span>
        )}
      </div>
    </div>
  </div>
</article>

<style>
  .case {
    position: relative;
    overflow: hidden;
    border-radius: var(--r-card);
    min-height: 300px;
    background: var(--lb);
    border: 1px solid var(--line);
    cursor: default;
  }

  /* FRONT */
  .front {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: var(--sp-6);
  }
  .logo-img {
    max-width: 70%;
    max-height: 60%;
    object-fit: contain;
  }
  .mono {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--step-5);
    color: var(--lc);
  }

  /* BACK (curtain slides up) */
  .back {
    position: absolute;
    inset: 0;
    transform: translateY(100%);
    transition: transform 0.42s cubic-bezier(0.4, 0, 0.2, 1);
    background: rgba(14, 10, 20, 0.97);
    border-radius: var(--r-card);
    border: 1px solid var(--line-strong);
    padding: var(--sp-5);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--sp-3);
  }
  .case:hover .back {
    transform: translateY(0);
  }

  .back-top {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .tag {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--brand-glow);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .back h3 {
    font-size: var(--step-2);
    color: var(--paper);
  }
  .desc {
    color: var(--muted);
    font-size: var(--step--1);
    line-height: 1.5;
  }

  .back-bottom {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .stack-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .stack-tags li {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    padding: 3px 8px;
    border: 1px solid var(--line-strong);
    border-radius: var(--r-pill);
    color: var(--muted);
    background: rgba(123, 47, 181, 0.10);
  }
  .actions {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    flex-wrap: wrap;
  }
  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--paper);
    font-weight: 600;
    font-size: var(--step--1);
    background: var(--brand);
    padding: 7px 14px;
    border-radius: var(--r-pill);
    transition: background 0.2s, transform 0.2s;
  }
  .read-more:hover {
    background: var(--brand-lift);
    transform: translateX(2px);
  }
  .visit {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: var(--muted);
    font-size: var(--step--2);
    font-family: var(--font-mono);
    transition: color 0.2s;
  }
  .visit:hover { color: var(--paper); }
  .visit .dom { color: var(--brand-glow); }
  .no-url {
    font-size: var(--step--2);
    color: var(--muted);
    font-style: italic;
  }
</style>
