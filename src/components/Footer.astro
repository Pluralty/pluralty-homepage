---
import logo from '../assets/isologotipo-blanco.webp';
import Tr from './Tr.astro';
import Icon from './Icon.astro';
import LangToggle from './LangToggle.astro';

const socials = [
  { icon: 'linkedin', label: 'LinkedIn', url: 'https://www.linkedin.com/in/arieldevops/' },
  { icon: 'x', label: 'X', url: 'https://x.com/ariel_devops' },
  { icon: 'youtube', label: 'YouTube', url: 'https://www.youtube.com/@arieldevops' },
  { icon: 'instagram', label: 'Instagram', url: 'https://www.instagram.com/arieldevops' },
  { icon: 'tiktok', label: 'TikTok', url: 'https://www.tiktok.com/@arieldevops' },
];
const year = 2026;
---

<footer class="footer">
  <div class="wrap top">
    <div class="brand-col">
      <img src={logo.src} alt="Pluralty" width="170" height="38" />
      <p class="tagline"><Tr k="footer.tagline" as="span" /></p>
      <a class="portal" href="https://pluralty.odoo.com/my" target="_blank" rel="noopener">
        <Tr k="footer.portal" /><Icon name="arrow" size={16} />
      </a>
    </div>

    <div class="col">
      <span class="col-h"><Tr k="footer.nav" /></span>
      <a href="#services"><Tr k="nav.services" /></a>
      <a href="#cases"><Tr k="nav.cases" /></a>
      <a href="#founder"><Tr k="nav.founder" /></a>
      <a href="#contact"><Tr k="nav.contact" /></a>
    </div>

    <div class="col">
      <span class="col-h"><Tr k="footer.connect" /></span>
      <ul class="social">
        {
          socials.map((s) => (
            <li>
              <a href={s.url} target="_blank" rel="noopener" aria-label={s.label}>
                <Icon name={s.icon} size={18} /> {s.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="wrap bottom">
    <span class="copy">© {year} Pluralty. <Tr k="footer.rights" /></span>
    <span class="built"><Tr k="footer.built" /></span>
    <LangToggle />
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    background: var(--ink-2);
    padding-top: var(--sp-8);
  }
  .top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--sp-7);
    padding-bottom: var(--sp-7);
  }
  .brand-col img {
    height: 36px;
    width: auto;
  }
  .tagline {
    margin-top: var(--sp-4);
    color: var(--muted);
    max-width: 38ch;
  }
  .portal {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: var(--sp-4);
    color: var(--brand-glow);
    font-weight: 600;
  }
  .col {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .col-h {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-bottom: var(--sp-1);
  }
  .col a {
    color: var(--paper);
    transition: color 0.2s;
  }
  .col a:hover {
    color: var(--brand-glow);
  }
  .social {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .social a {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
  }
  .bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    flex-wrap: wrap;
    padding-block: var(--sp-5);
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: var(--step--1);
  }
  .built {
    font-family: var(--font-mono);
  }

  @media (max-width: 820px) {
    .top {
      grid-template-columns: 1fr 1fr;
    }
    .brand-col {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 520px) {
    .top {
      grid-template-columns: 1fr;
    }
  }
</style>
