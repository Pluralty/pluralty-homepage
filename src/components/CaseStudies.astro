---
import Tr from './Tr.astro';
import CaseStudyCard from './CaseStudyCard.astro';
import stabletLogo from '../assets/stabled-logo.png';
import tradepLogo from '../assets/tradeprentice-logo.png';
import muchLogo from '../assets/MUCHTICKET.png';

const cases = [
  {
    id: 'stabled',
    name: 'stabled.co',
    display: 'Stabled',
    url: 'https://stabled.co',
    detailUrl: '/cases/stabled',
    stack: ['AWS Organizations', 'ALB', 'ECS', 'RDS', 'GitHub Actions', 'Terraform'],
    logoImg: stabletLogo,
    logoColor: '#FFFFFF',
    logoBg: '#1B6CA8',
  },
  {
    id: 'tradeprentice',
    name: 'tradeprentice.io',
    display: 'Tradeprentice',
    url: 'https://tradeprentice.io',
    detailUrl: undefined,
    stack: ['AWS Organizations', 'ALB', 'ECS', 'RDS', 'GitHub Actions', 'Terraform'],
    logoImg: tradepLogo,
    logoColor: '#374151',
    logoBg: '#F3F4F6',
  },
  {
    id: 'muchticket',
    name: 'muchticket.com',
    display: 'Muchticket',
    url: 'https://www.muchticket.com',
    detailUrl: undefined,
    stack: ['AWS Organizations', 'ALB', 'ECS', 'RDS', 'Terraform'],
    logoImg: muchLogo,
    logoColor: '#00B5D8',
    logoBg: '#FFFFFF',
  },
  {
    id: 'pgsa',
    name: undefined,
    display: 'PGSA',
    url: undefined,
    detailUrl: undefined,
    stack: ['AWS Organizations', 'AWS Workspaces', 'Active Directory', 'Terraform'],
    logoImg: undefined,
    logoColor: '#0078D4',
    logoBg: 'rgba(0,120,212,0.14)',
    logoText: 'PG',
  },
];
---

<section class="section" id="cases">
  <div class="wrap">
    <header class="head" data-reveal>
      <span class="eyebrow"><Tr k="cases.eyebrow" /></span>
      <h2><Tr k="cases.title" as="span" /></h2>
      <p class="lead"><Tr k="cases.sub" as="span" /></p>
    </header>

    <div class="grid">
      {cases.map((c, i) => <CaseStudyCard {...c} index={i} />)}
    </div>
  </div>
</section>

<style>
  .head {
    max-width: 48rem;
    margin-bottom: var(--sp-7);
  }
  .head h2 {
    font-size: var(--step-4);
    margin-top: var(--sp-3);
  }
  .head .lead {
    margin-top: var(--sp-4);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-4);
    align-items: start;
  }
  @media (max-width: 720px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
