---
import Tr from './Tr.astro';
import CaseStudyCard from './CaseStudyCard.astro';

const cases = [
  {
    id: 'stabled',
    name: 'stabled.co',
    display: 'Stabled',
    url: 'https://stabled.co',
    detailUrl: '/cases/stabled',
    stack: ['AWS Organizations', 'ALB', 'ECS', 'RDS', 'GitHub Actions', 'Terraform'],
    // Monogram: violet fintech feel
    logoColor: '#7B2FB5',
    logoBg: 'rgba(123,47,181,0.18)',
    logoText: 'S',
  },
  {
    id: 'tradeprentice',
    name: 'tradeprentice.io',
    display: 'Tradeprentice',
    url: 'https://tradeprentice.io',
    detailUrl: undefined,
    stack: ['AWS Organizations', 'ALB', 'ECS', 'RDS', 'GitHub Actions', 'Terraform'],
    logoColor: '#2563EB',
    logoBg: 'rgba(37,99,235,0.14)',
    logoText: 'TP',
  },
  {
    id: 'muchticket',
    name: 'muchticket.com',
    display: 'Muchticket',
    url: 'https://www.muchticket.com',
    detailUrl: undefined,
    stack: ['AWS Organizations', 'ALB', 'ECS', 'RDS', 'Terraform'],
    logoColor: '#E05000',
    logoBg: 'rgba(224,80,0,0.14)',
    logoText: 'MT',
  },
  {
    id: 'pgsa',
    name: undefined,
    display: 'PGSA',
    url: undefined,
    detailUrl: undefined,
    stack: ['AWS Organizations', 'AWS Workspaces', 'Active Directory', 'Terraform'],
    logoColor: '#0078D4',
    logoBg: 'rgba(0,120,212,0.14)',
    logoText: 'PG',
  },
];
---

<section class="section" id="cases">
  <div class="wrap">
    <header class="head" data-reveal>
      <span class="eyebrow"><Tr k="cases.eyebrow" /></span>
      <h2><Tr k="cases.title" as="span" /></h2>
      <p class="lead"><Tr k="cases.sub" as="span" /></p>
    </header>

    <div class="list">
      {cases.map((c, i) => <CaseStudyCard {...c} index={i} />)}
    </div>
  </div>
</section>

<style>
  .head {
    max-width: 48rem;
    margin-bottom: var(--sp-7);
  }
  .head h2 {
    font-size: var(--step-4);
    margin-top: var(--sp-3);
  }
  .head .lead {
    margin-top: var(--sp-4);
  }
  .list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
</style>
