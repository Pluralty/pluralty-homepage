---
// Renders a translatable string in the default locale, tagged with data-i18n
// so the client-side language toggle can swap it. Values may contain trusted
// inline HTML (set:html), which is why we author the dictionaries ourselves.
import { t } from '../i18n';

interface Props {
  k: string;
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}

const { k, as = 'span', class: className } = Astro.props;
const Tag = as;
const value = t(k);
---

<Tag data-i18n={k} class={className} set:html={value} />
