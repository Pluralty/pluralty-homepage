---
import Tr from './Tr.astro';

const items = [
  {
    k: 'tdsynnex',
    abbr: 'TD\nSYNNEX',
    color: '#005B9A',
    bg: 'rgba(0,91,154,0.15)',
  },
  {
    k: 'aws',
    abbr: 'AWS',
    color: '#FF9900',
    bg: 'rgba(255,153,0,0.12)',
    svg: `<svg viewBox="0 0 48 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M12 3h3l2 8 2-6h2l2 6 2-8h3L25 17h-3L20.5 10 19 17h-3z" fill="#FF9900"/>
      <path d="M9 14 Q24 20 39 14" stroke="#FF9900" stroke-width="2.5" stroke-linecap="round" fill="none"/>
      <path d="M37 12 L39 14 L35 15" stroke="#FF9900" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>`,
  },
  {
    k: 'cert',
    abbr: '✓\nCERT',
    color: '#7B2FB5',
    bg: 'rgba(123,47,181,0.15)',
  },
];
---

<section class="section" id="partners">
  <div class="wrap">
    <header class="head" data-reveal>
      <span class="eyebrow"><Tr k="partners.eyebrow" /></span>
      <h2><Tr k="partners.title" as="span" /></h2>
    </header>
    <div class="grid">
      {
        items.map((it, i) => (
          <article class="trust-card" data-reveal style={`--reveal-delay:${i * 0.06}s`}>
            <div class="logo-area" style={`--lc:${it.color};--lb:${it.bg}`}>
              {it.svg ? (
                <Fragment set:html={it.svg} />
              ) : (
                <span class="abbr">{it.abbr}</span>
              )}
            </div>
            <h3>
              <Tr k={`partners.${it.k}.t`} />
            </h3>
            <p>
              <Tr k={`partners.${it.k}.d`} as="span" />
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .head {
    max-width: 44rem;
    margin-bottom: var(--sp-7);
  }
  .head h2 {
    font-size: var(--step-3);
    margin-top: var(--sp-3);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }
  .trust-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-card);
    padding: var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    transition: border-color 0.3s, transform var(--dur) var(--ease);
  }
  .trust-card:hover {
    border-color: var(--line-strong);
    transform: translateY(-2px);
  }
  .logo-area {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 52px;
    border-radius: 10px;
    background: var(--lb, rgba(75,0,118,0.15));
    border: 1px solid color-mix(in srgb, var(--lc, var(--brand)) 30%, transparent);
  }
  .logo-area :global(svg) {
    width: 52px;
    height: auto;
  }
  .abbr {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--lc, var(--brand-glow));
    white-space: pre;
    text-align: center;
    line-height: 1.3;
  }
  .trust-card h3 {
    font-size: var(--step-1);
  }
  .trust-card p {
    color: var(--muted);
    font-size: var(--step-0);
    flex: 1;
  }
  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
