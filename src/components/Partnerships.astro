---
import Tr from './Tr.astro';
const items = [
  { k: 'tdsynnex', mark: 'TD SYNNEX' },
  { k: 'aws', mark: 'AWS Partner' },
  { k: 'cert', mark: 'AWS Certified' },
];
---

<section class="section" id="partners">
  <div class="wrap">
    <header class="head" data-reveal>
      <span class="eyebrow"><Tr k="partners.eyebrow" /></span>
      <h2><Tr k="partners.title" as="span" /></h2>
    </header>
    <div class="grid">
      {
        items.map((it, i) => (
          <article class="trust-card" data-reveal style={`--reveal-delay:${i * 0.06}s`}>
            <span class="mark">{it.mark}</span>
            <h3>
              <Tr k={`partners.${it.k}.t`} />
            </h3>
            <p>
              <Tr k={`partners.${it.k}.d`} as="span" />
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .head {
    max-width: 44rem;
    margin-bottom: var(--sp-7);
  }
  .head h2 {
    font-size: var(--step-3);
    margin-top: var(--sp-3);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }
  .trust-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-card);
    padding: var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .mark {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.08em;
    color: var(--brand-glow);
    padding: 6px 12px;
    border: 1px solid var(--line-strong);
    border-radius: var(--r-pill);
    align-self: flex-start;
  }
  .trust-card h3 {
    font-size: var(--step-1);
    margin-top: var(--sp-2);
  }
  .trust-card p {
    color: var(--muted);
    font-size: var(--step-0);
  }
  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
