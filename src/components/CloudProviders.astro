---
import Tr from './Tr.astro';
const clouds = ['AWS', 'Microsoft Azure', 'Google Cloud'];
---

<section class="clouds" aria-label="Cloud providers">
  <div class="wrap inner" data-reveal>
    <div class="copy">
      <span class="eyebrow"><Tr k="clouds.eyebrow" /></span>
      <h2><Tr k="clouds.title" as="span" /></h2>
      <p class="lead"><Tr k="clouds.sub" as="span" /></p>
    </div>
    <ul class="logos">
      {clouds.map((c) => <li>{c}</li>)}
    </ul>
  </div>
</section>

<style>
  .clouds {
    border-block: 1px solid var(--line);
    background: var(--ink-2);
  }
  .inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-7);
    align-items: center;
    padding-block: var(--sp-8);
  }
  .copy h2 {
    font-size: var(--step-2);
    margin-top: var(--sp-3);
  }
  .copy .lead {
    margin-top: var(--sp-3);
    font-size: var(--step-0);
  }
  .logos {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    justify-content: flex-end;
  }
  .logos li {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step-1);
    color: var(--paper);
    padding: 14px 22px;
    border: 1px solid var(--line-strong);
    border-radius: var(--r-card);
    background: var(--surface);
  }
  @media (max-width: 820px) {
    .inner {
      grid-template-columns: 1fr;
      gap: var(--sp-5);
    }
    .logos {
      justify-content: flex-start;
    }
  }
</style>
