---
import Tr from './Tr.astro';
import awsLogo from '../assets/aws-blanco.png';
import azureLogo from '../assets/Microsoft_Azure.svg.png';
import gcpLogo from '../assets/google-cloud.png';

const clouds = [
  { img: awsLogo,   alt: 'AWS',            label: 'AWS',            color: '#FF9900', bg: 'rgba(255,153,0,0.06)' },
  { img: azureLogo, alt: 'Microsoft Azure', label: 'Microsoft Azure', color: '#0078D4', bg: 'rgba(0,120,212,0.06)' },
  { img: gcpLogo,   alt: 'Google Cloud',    label: 'Google Cloud',    color: '#34A853', bg: 'rgba(52,168,83,0.06)' },
];
---

<section class="clouds" aria-label="Cloud providers">
  <div class="wrap" data-reveal>
    <div class="copy">
      <span class="eyebrow"><Tr k="clouds.eyebrow" /></span>
      <h2><Tr k="clouds.title" as="span" /></h2>
      <p class="lead"><Tr k="clouds.sub" as="span" /></p>
    </div>
    <ul class="logos">
      {
        clouds.map((c) => (
          <li style={`--cc:${c.color};--cb:${c.bg}`}>
            <div class="logo-img-wrap">
              <img src={c.img.src} alt={c.alt} loading="lazy" decoding="async" />
            </div>
            <span class="cloud-name">{c.label}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .clouds {
    border-block: 1px solid var(--line);
    background: var(--ink-2);
  }
  .wrap {
    padding-block: var(--sp-8);
  }
  .copy {
    max-width: 42rem;
    margin-bottom: var(--sp-7);
  }
  .copy h2 {
    font-size: var(--step-2);
    margin-top: var(--sp-3);
  }
  .copy .lead {
    margin-top: var(--sp-3);
    font-size: var(--step-0);
  }
  .logos {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }
  .logos li {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-4);
    padding: var(--sp-7) var(--sp-5);
    border: 1px solid var(--line-strong);
    border-radius: var(--r-card);
    background: var(--surface);
    transition: border-color 0.3s, transform var(--dur) var(--ease), background 0.3s;
  }
  .logos li:hover {
    border-color: color-mix(in srgb, var(--cc) 50%, transparent);
    background: var(--cb);
    transform: translateY(-3px);
  }
  .logo-img-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 64px;
  }
  .logo-img-wrap img {
    max-height: 64px;
    max-width: 160px;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .cloud-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step-0);
    color: var(--paper);
  }
  @media (max-width: 720px) {
    .logos {
      grid-template-columns: 1fr;
    }
  }
</style>
