---
import Icon from './Icon.astro';
import Tr from './Tr.astro';

const clouds = [
  { icon: 'aws',   label: 'AWS',           color: '#FF9900', bg: 'rgba(255,153,0,0.08)' },
  { icon: 'azure', label: 'Microsoft Azure', color: '#0078D4', bg: 'rgba(0,120,212,0.08)' },
  { icon: 'gcp',   label: 'Google Cloud',   color: '#4285F4', bg: 'rgba(66,133,244,0.08)' },
];
---

<section class="clouds" aria-label="Cloud providers">
  <div class="wrap inner" data-reveal>
    <div class="copy">
      <span class="eyebrow"><Tr k="clouds.eyebrow" /></span>
      <h2><Tr k="clouds.title" as="span" /></h2>
      <p class="lead"><Tr k="clouds.sub" as="span" /></p>
    </div>
    <ul class="logos">
      {
        clouds.map((c) => (
          <li style={`--cc:${c.color};--cb:${c.bg}`}>
            <span class="icon-wrap">
              <Icon name={c.icon} size={28} />
            </span>
            {c.label}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .clouds {
    border-block: 1px solid var(--line);
    background: var(--ink-2);
  }
  .inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-7);
    align-items: center;
    padding-block: var(--sp-8);
  }
  .copy h2 {
    font-size: var(--step-2);
    margin-top: var(--sp-3);
  }
  .copy .lead {
    margin-top: var(--sp-3);
    font-size: var(--step-0);
  }
  .logos {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    justify-content: flex-end;
  }
  .logos li {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step-0);
    color: var(--paper);
    padding: 14px 20px;
    border: 1px solid var(--line-strong);
    border-radius: var(--r-card);
    background: var(--surface);
    transition: border-color 0.3s, transform var(--dur) var(--ease), background 0.3s;
  }
  .logos li:hover {
    border-color: color-mix(in srgb, var(--cc) 40%, transparent);
    background: var(--cb);
    transform: translateY(-2px);
  }
  .icon-wrap {
    color: var(--cc);
    display: flex;
    align-items: center;
  }
  @media (max-width: 820px) {
    .inner {
      grid-template-columns: 1fr;
      gap: var(--sp-5);
    }
    .logos {
      justify-content: flex-start;
    }
  }
</style>
